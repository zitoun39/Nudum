# Nudum Environment Configuration Template

# General Settings
PORT=5000
NODE_ENV=development

# Database Settings (PgBouncer port is usually 6432, direct postgres is 5432)
DB_HOST=localhost
DB_PORT=5432
DB_USER=nudum_admin
DB_PASSWORD=nudum_secure_pass_2026
DB_NAME=nudum_db

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379

# Object Storage Settings (MinIO)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secure_pass_2026
MINIO_BUCKET=nudum-assets

# Authentication Settings
JWT_SECRET=nudum_jwt_secret_anchor_2026_super_long_key
JWT_REFRESH_SECRET=nudum_jwt_refresh_secret_anchor_2026_super_long_key
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
