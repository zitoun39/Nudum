# Nudum Environment Configuration Template

# General Settings
PORT=5000
NODE_ENV=development

# Database Settings (PgBouncer port is usually 6432, direct postgres is 5432)
DB_HOST=localhost
DB_PORT=5432
DB_USER=nudum_admin
DB_PASSWORD=your_secure_database_password
DB_NAME=nudum_db

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379

# Object Storage Settings (MinIO)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=your_secure_minio_password
MINIO_BUCKET=nudum-assets

# Authentication Settings
JWT_SECRET=your_super_long_random_jwt_access_secret_key
JWT_REFRESH_SECRET=your_super_long_random_jwt_refresh_secret_key
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
